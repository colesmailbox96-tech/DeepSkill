# Veilmarch — environment configuration
#
# Copy this file to .env.local and fill in any values before running.
# Currently Veilmarch has no required environment variables — the game runs
# entirely in the browser with no server-side dependencies.
#
# Uncomment and set the lines below if you add server-side features in a
# later phase (e.g. Phase 46+ cloud sync, analytics, etc.).

# VITE_API_BASE_URL=https://api.example.com
